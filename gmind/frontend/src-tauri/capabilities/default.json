{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main", "capture"],
  "permissions": [
    "core:default",
    "core:webview:allow-set-webview-focus",
    "shell:allow-open",
    "shell:allow-execute",
    "shell:allow-spawn",
    "dialog:default",
    "global-shortcut:default",
    "stronghold:default",
    "autostart:default",
    "store:default"
  ]
}
